TEAMS_WEBHOOK_URL=

# Check interval in milliseconds (default: 60000 = 1 min)
CHECK_INTERVAL_MS=60000

# Device code expiry in milliseconds (default: 600000 = 10 min)
# Login process is killed 1 min before this to allow a fresh code
DEVICE_CODE_EXPIRES_MS=600000

# Log file path (default: app.log)
LOG_FILE=app.log

# Kiro CLI configuration (optional)
# KIRO_LICENSE=pro
# KIRO_IDENTITY_PROVIDER=
# KIRO_REGION=us-east-1
